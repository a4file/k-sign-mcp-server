# Server
NODE_ENV=development
LOG_LEVEL=info

# MCP transport: stdio | http
MCP_TRANSPORT=stdio
MCP_SERVER_NAME=k-sign-mcp-server
MCP_SERVER_VERSION=0.1.0

# HTTP mode (when MCP_TRANSPORT=http)
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
PORT=8000

# Database
DB_PROVIDER=sqlite
SQLITE_PATH=./data/ksign.db

# PostgreSQL (future use — set DB_PROVIDER=postgres)
# POSTGRES_URL=postgresql://user:password@localhost:5432/ksign

# Search
SEARCH_RESULT_LIMIT=20

# Public data collection (국립국어원 수어 Open API — 키가 API마다 다를 수 있음)
# 방법 A) 하나의 키로 전부 커버될 때만:
# DATA_GO_KR_SERVICE_KEY=공통키
#
# 방법 B) API별로 키가 다를 때 (권장):
DATA_GO_KR_SERVICE_KEY_DAILY=        # 일상생활 수어 (getCTE01701)
DATA_GO_KR_SERVICE_KEY_PROFESSIONAL= # 전문용어 수어 (getCTE01702)
DATA_GO_KR_SERVICE_KEY_CULTURE=     # 문화정보 수어 (getCTE01703)
DATA_GO_KR_SERVICE_KEY_COMPREHENSIVE= # 통합 수어정보 (API_CNV_054)
#
# 개별 키를 하나라도 넣으면, 나머지는 공통키로 자동 대체되지 않습니다.
# 해당 API 키만 넣은 데이터셋만 수집됩니다.
DATA_GO_KR_SERVICE_KEY=
# api.kcisa.kr DNS 미해결 환경용 (기본값 유지 권장)
KCISA_API_IP_FALLBACK=175.125.91.8
COLLECT_ON_START=false
COLLECT_PAGE_SIZE=100
COLLECT_REQUEST_DELAY_MS=200
USE_SAMPLE_DATA=false
