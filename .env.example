# Server
NODE_ENV=development
LOG_LEVEL=info

# MCP transport: stdio | http
MCP_TRANSPORT=stdio
MCP_SERVER_NAME=k-sign-mcp-server
MCP_SERVER_VERSION=0.1.0

# HTTP mode (when MCP_TRANSPORT=http)
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
PORT=8000

# Database
DB_PROVIDER=sqlite
SQLITE_PATH=./data/ksign.db

# PostgreSQL (future use — set DB_PROVIDER=postgres)
# POSTGRES_URL=postgresql://user:password@localhost:5432/ksign

# Search
SEARCH_RESULT_LIMIT=20

# Public data collection (문화체육관광부 / 국립국어원 수어 Open API)
# https://www.data.go.kr 에서 일상생활/전문용어/문화정보 수어 API 활용신청 후 발급
DATA_GO_KR_SERVICE_KEY=
COLLECT_ON_START=false
COLLECT_PAGE_SIZE=100
COLLECT_REQUEST_DELAY_MS=200
USE_SAMPLE_DATA=false
